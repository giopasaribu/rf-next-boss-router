{
  "name": "rf-next-boss-router",
  "version": "1.0.0",
  "description": "RF Boss Announcement Router — paste raw boss announcements, preview the parsed routing, and fan out to per-guild Discord webhooks + a personal Telegram copy.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
