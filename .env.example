# ---------------------------------------------------------------------------
# RF Boss Announcement Router — environment configuration
#
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Port the Fastify server listens on.
PORT=3000

# Network interface to bind. Leave as 0.0.0.0 for a normal deployment behind a
# reverse proxy/firewall. Set to 127.0.0.1 to make it reachable ONLY from the
# VPS itself (e.g. for a private first test over an SSH tunnel).
HOST=0.0.0.0

# LLM parsing via Groq's free, OpenAI-compatible API.
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=
# Model to use. llama-3.3-70b-versatile = best quality (free). For faster/cheaper
# parsing you can use llama-3.1-8b-instant. Must be a model your key can access.
GROQ_MODEL=llama-3.3-70b-versatile
# API endpoint (rarely needs changing).
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# ---------------------------------------------------------------------------
# Discord webhooks — one per guild.
# Get these from: Discord channel -> Edit Channel -> Integrations -> Webhooks.
# ---------------------------------------------------------------------------
WEBHOOK_GGI=
WEBHOOK_EMP=
WEBHOOK_EMPIRE=

# Fallback channel for unparseable / invalid announcements ("needs review").
WEBHOOK_NEEDS_REVIEW=

# ---------------------------------------------------------------------------
# Discord role pings (optional) — prepended to the message for that guild.
# Format: <@&123456789012345678>
# ---------------------------------------------------------------------------
ROLE_ID_GGI=
ROLE_ID_EMP=
ROLE_ID_EMPIRE=

# ---------------------------------------------------------------------------
# Telegram — the developer's personal copy of every confirmed announcement.
# TELEGRAM_BOT_TOKEN from @BotFather; TELEGRAM_CHAT_ID is your personal chat id.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Simple shared secret that gates the form and the API endpoints so random
# people on the internet can't drive the fan-out. Set a long random string.
# ---------------------------------------------------------------------------
APP_SHARED_SECRET=
