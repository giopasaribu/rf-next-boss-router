# ---------------------------------------------------------------------------
# RF Boss Announcement Router — process configuration.
#
# Copy to `.env`. There are NO secrets here: guilds, webhooks, Telegram tokens,
# bosses, the schedule and the watchlist are all managed in the web UI and saved
# to the JSON data store (data/db.json). This app has NO auth — run it on a
# PRIVATE, non-internet-exposed server only.
# ---------------------------------------------------------------------------

# Port + interface the server listens on.
PORT=3000
HOST=0.0.0.0

# Where app state + the reminder "fired today" log are persisted.
# MUST be on a persistent disk so the schedule and reminders survive a restart.
# Defaults to ./data/db.json and ./data/reminders-fired.json if left blank.
DB_PATH=
FIRED_PATH=
